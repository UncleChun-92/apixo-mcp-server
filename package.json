{
  "name": "@apixo/mcp-server",
  "version": "0.2.1",
  "description": "APiXO MCP server for local tool integrations",
  "type": "module",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "apixo-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "check": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "apixo",
    "mcp",
    "model-context-protocol"
  ],
  "author": "APiXO",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
